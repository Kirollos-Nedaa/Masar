@using Masar.Domain.ViewModels.AuthDtos
@model ForgotPasswordDto

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<h1 class="auth-heading">Forgot your password?</h1>
<p class="auth-subheading">
    Enter the email address linked to your account and we'll get you back in.
</p>

@* ── Validation banner ─────────────────────────────────── *@
<div class="validation-wrapper" id="validationBox" style="display:none;">
    <span class="iconify" data-icon="lucide:circle-x"></span>
    <div class="validation-content">
        <div asp-validation-summary="ModelOnly"></div>
    </div>
</div>

<form asp-controller="Auth" asp-action="ForgotPassword" method="post" novalidate>
    @Html.AntiForgeryToken()

    <div class="mb-4">
        <label class="form-label">Email address</label>
        <input asp-for="Email"
               class="form-control"
               placeholder="you@example.com"
               autocomplete="email"
               autofocus />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn-cb-primary">
        Continue &nbsp;<span class="iconify" data-icon="lucide:arrow-right" style="font-size:1.2rem;"></span>
    </button>
</form>

<div class="signin-link">
    Remembered it? <a asp-controller="Auth" asp-action="Login">Sign in</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const box = document.getElementById('validationBox');
            if (box) {
                const hasErrors = box.querySelectorAll('li').length > 0
                    || box.querySelector('[data-valmsg-summary]')
                          ?.querySelectorAll('li').length > 0;
                box.style.display = hasErrors ? 'flex' : 'none';
            }
        })();
    </script>
}
