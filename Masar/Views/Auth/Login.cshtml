@model Masar.Domain.ViewModels.LoginDto

@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}

<h1 class="auth-heading">Welcome back</h1>
<p class="auth-subheading">Sign in to your Masar account</p>

<form asp-controller="Auth" asp-action="Login" method="post" novalidate>
    @Html.AntiForgeryToken()

    @* Validation Summary *@
    <div class="validation-wrapper" style="display:none;">
        <span class="iconify" data-icon="lucide:circle-x"></span>
        <div asp-validation-summary="ModelOnly" class="validation-content"></div>
    </div>

    @* Email *@
    <div class="mb-3">
        <label class="form-label">Email address</label>
        <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    @* Password *@
    <div class="mb-3">
        <label class="form-label">Password</label>
        <div class="pw-wrap">
            <input asp-for="Password" type="password" id="pw" class="form-control" placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="btn-toggle-pw" onclick="togglePw('pw','eyePw')" tabindex="-1" aria-label="Toggle password">
                <span class="iconify" data-icon="lucide:eye" id="eyePw"></span>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    @* Remember Me + Forgot Password *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
            <label asp-for="RememberMe" class="form-check-label">Remember me</label>
        </div>
        <a asp-action="ForgotPassword" class="small text-decoration-none">Forgot password?</a>
    </div>

    @* Submit *@
    <button type="submit" class="btn-cb-primary">Sign In</button>
</form>

@* Register link *@
<div class="signin-link">
    Don't have an account?
    <a asp-controller="Auth" asp-action="Register">Create one</a>
</div>

@* Social divider *@
<div class="auth-divider">or continue with</div>

<div class="row g-2">
    <div class="col-12">
        <button type="button" class="btn-social" id="googleBtn">
            <span class="iconify" data-icon="logos:google-icon"></span> Google
        </button>
        <div id="google-hidden-btn" style="display:none;"></div>
        <div id="google-error" class="validation-box mt-2" style="display:none;"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const box = document.querySelector('.validation-wrapper');
            if (box) {
                const content = box.querySelector('.validation-content');
                if (content && content.querySelectorAll('li').length > 0) {
                    box.style.display = 'flex';
                }
            }
        })();

        function togglePw(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-icon', 'lucide:eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-icon', 'lucide:eye');
            }
        }

        async function handleGoogleCredential(response) {
            const idToken = response.credential ?? response.id_token;

            if (!idToken) {
                console.error('No token found in response:', response);
                return;
            }

            const token = document.querySelector('input[name=__RequestVerificationToken]');
            if (!token) {
                console.error('Antiforgery token not found');
                return;
            }

            const res = await fetch('/Auth/GoogleAuth', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token.value
                },
                body: 'idToken=' + encodeURIComponent(idToken)
            });

            const data = await res.json();
            console.log('Server response:', data);

            if (data.success) {
                window.location.href = data.redirectUrl;
            } else {
                const err = document.getElementById('google-error');
                err.textContent = data.error;
                err.style.display = 'block';
            }
        }

        function initGoogleSignIn() {
            google.accounts.id.initialize({
                client_id: '@System.Environment.GetEnvironmentVariable("GOOGLE_CLIENT_ID")',
                callback: handleGoogleCredential
            });

            google.accounts.id.renderButton(
                document.getElementById('google-hidden-btn'),
                { theme: 'outline', size: 'large', type: 'standard' }
            );

            document.getElementById('googleBtn').addEventListener('click', function () {
                document.getElementById('google-hidden-btn').querySelector('div[role=button]').click();
            });
        }
    </script>

    <script src="https://accounts.google.com/gsi/client" onload="initGoogleSignIn()"></script>
}