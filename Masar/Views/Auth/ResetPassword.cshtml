@using Masar.Domain.ViewModels.AuthDtos
@model ResetPasswordDto

@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AuthLayout";
}

<h1 class="auth-heading">Set a new password</h1>
<p class="auth-subheading">Choose something strong that you haven't used before.</p>

@* ── Validation banner ─────────────────────────────────── *@
<div class="validation-wrapper" id="validationBox" style="display:none;">
    <span class="iconify" data-icon="lucide:circle-x"></span>
    <div class="validation-content">
        <div asp-validation-summary="ModelOnly"></div>
    </div>
</div>

<form asp-controller="Auth" asp-action="ResetPassword" method="post" novalidate>
    @Html.AntiForgeryToken()

    @* Hidden fields — carry the reset token pair through the form *@
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="Token" />

    @* ── New Password ──────────────────────────────────────── *@
    <div class="mb-3">
        <label class="form-label">New password</label>
        <div class="pw-wrap">
            <input asp-for="NewPassword"
                   type="password"
                   id="pw"
                   class="form-control"
                   placeholder="Min. 8 characters"
                   autocomplete="new-password" />
            <button type="button"
                    class="btn-toggle-pw"
                    onclick="togglePw('pw','eyePw')"
                    tabindex="-1"
                    aria-label="Toggle password">
                <span class="iconify" data-icon="lucide:eye" id="eyePw"></span>
            </button>
        </div>
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>

    @* ── Confirm Password ──────────────────────────────────── *@
    <div class="mb-4">
        <label class="form-label">Confirm new password</label>
        <div class="pw-wrap">
            <input asp-for="ConfirmPassword"
                   type="password"
                   id="cpw"
                   class="form-control"
                   placeholder="Repeat your new password"
                   autocomplete="new-password" />
            <button type="button"
                    class="btn-toggle-pw"
                    onclick="togglePw('cpw','eyeCpw')"
                    tabindex="-1"
                    aria-label="Toggle confirm password">
                <span class="iconify" data-icon="lucide:eye" id="eyeCpw"></span>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn-cb-primary">
        <span class="iconify" data-icon="lucide:lock-keyhole" style="font-size:1.1rem;"></span>
        &nbsp;Reset Password
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show validation box when server returns errors
        (function () {
            const box = document.getElementById('validationBox');
            if (!box) return;
            const hasSummaryErrors = box.querySelectorAll('li').length > 0;
            box.style.display = hasSummaryErrors ? 'flex' : 'none';
        })();

        function togglePw(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-icon', 'lucide:eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-icon', 'lucide:eye');
            }
        }
    </script>
}
