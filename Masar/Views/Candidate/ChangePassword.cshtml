@using Masar.Domain.ViewModels.AuthDtos
@model ChangePasswordDto

@{
    // ViewData["ReturnController"] is set by the calling controller so the
    // Back / Cancel link knows where to return (Candidate or Company).
    var returnController = ViewData["ReturnController"]?.ToString() ?? "Candidate";
    var isCandidate      = returnController == "Candidate";

    ViewData["Title"]      = "Change Password";
    ViewData["HasSidebar"] = true;
}

@section Sidebar {
    @if (isCandidate)
    {
        <partial name="_CandidateSidebar" />
    }
    else
    {
        <partial name="_CompanySidebar" />
    }
}

@* ── Page Header ──────────────────────────────────────────── *@
<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title">Change Password</h1>
        <p class="page-subtitle">Update your account password</p>
    </div>
    <a asp-controller="@returnController" asp-action="Profile" class="btn-outline-app">
        <span class="iconify" data-icon="lucide:arrow-left"></span> Back to Profile
    </a>
</div>

@* ── Server-side error banner ──────────────────────────────── *@
@if (!ViewData.ModelState.IsValid)
{
    <div class="epi-alert-error mb-4">
        <span class="iconify" data-icon="lucide:circle-alert"></span>
        @Html.ValidationSummary(false)
    </div>
}

@* ── Success banner (set via TempData on redirect) ────────── *@
@if (TempData["ChangePasswordSuccess"] is string successMsg)
{
    <div class="success-banner mb-4">
        <span class="iconify" data-icon="lucide:check-circle"></span>
        @successMsg
    </div>
}

<form asp-controller="@returnController"
      asp-action="ChangePassword"
      method="post"
      id="changePasswordForm">
    @Html.AntiForgeryToken()

    <div class="app-card">
        <div class="card-section-header mb-4">
            <div class="card-section-title">
                <span class="iconify me-2" data-icon="lucide:lock-keyhole"></span>
                Password Settings
            </div>
        </div>

        @* ── Current Password ──────────────────────────────── *@
        <div class="mb-3">
            <label class="epi-label">Current Password</label>
            <div class="pw-wrap position-relative">
                <input asp-for="CurrentPassword"
                       type="password"
                       id="pwCurrent"
                       class="epi-input"
                       placeholder="Enter your current password"
                       autocomplete="current-password" />
                <button type="button"
                        class="btn-toggle-pw-epi"
                        onclick="toggleField('pwCurrent','eyeCurrent')"
                        tabindex="-1"
                        aria-label="Toggle current password">
                    <span class="iconify" data-icon="lucide:eye" id="eyeCurrent"></span>
                </button>
            </div>
            <span asp-validation-for="CurrentPassword" class="epi-error"></span>
        </div>

        <div class="change-pw-divider"></div>

        @* ── New Password ──────────────────────────────────── *@
        <div class="mb-3">
            <label class="epi-label">New Password</label>
            <div class="pw-wrap position-relative">
                <input asp-for="NewPassword"
                       type="password"
                       id="pwNew"
                       class="epi-input"
                       placeholder="Min. 8 characters"
                       autocomplete="new-password"
                       oninput="checkStrength(this.value)" />
                <button type="button"
                        class="btn-toggle-pw-epi"
                        onclick="toggleField('pwNew','eyeNew')"
                        tabindex="-1"
                        aria-label="Toggle new password">
                    <span class="iconify" data-icon="lucide:eye" id="eyeNew"></span>
                </button>
            </div>
            <span asp-validation-for="NewPassword" class="epi-error"></span>

            @* ── Strength bar ──────────────────────────────── *@
            <div class="pw-strength-wrap mt-2" id="strengthWrap" style="display:none;">
                <div class="pw-strength-bar">
                    <div class="pw-strength-fill" id="strengthFill"></div>
                </div>
                <span class="pw-strength-label" id="strengthLabel"></span>
            </div>
        </div>

        @* ── Confirm New Password ──────────────────────────── *@
        <div class="mb-2">
            <label class="epi-label">Confirm New Password</label>
            <div class="pw-wrap position-relative">
                <input asp-for="ConfirmPassword"
                       type="password"
                       id="pwConfirm"
                       class="epi-input"
                       placeholder="Repeat your new password"
                       autocomplete="new-password" />
                <button type="button"
                        class="btn-toggle-pw-epi"
                        onclick="toggleField('pwConfirm','eyeConfirm')"
                        tabindex="-1"
                        aria-label="Toggle confirm password">
                    <span class="iconify" data-icon="lucide:eye" id="eyeConfirm"></span>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="epi-error"></span>
        </div>
    </div>

    @* ── Actions ──────────────────────────────────────────── *@
    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-controller="@returnController" asp-action="Profile" class="btn-outline-app">
            Cancel
        </a>
        <button type="submit" class="btn-primary-app">
            <span class="iconify" data-icon="lucide:save"></span> Save Password
        </button>
    </div>
</form>

@section Styles {
<style>
/* ── Toggle button inside epi-input ─────────────────── */
.btn-toggle-pw-epi {
    position: absolute;
    right: .75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 0;
    line-height: 1;
    font-size: 1.15rem;
    transition: color .15s;
    z-index: 2;
}
.btn-toggle-pw-epi:hover { color: var(--blue); }

/* Give the input room for the eye button */
.pw-wrap .epi-input { padding-right: 2.75rem; }

/* Divider between current and new password */
.change-pw-divider {
    height: 1px;
    background: var(--border);
    margin: 1.25rem 0;
}

/* ── Strength bar ──────────────────────────────────── */
.pw-strength-wrap {
    display: flex;
    align-items: center;
    gap: .625rem;
}
.pw-strength-bar {
    flex: 1;
    height: 4px;
    background: var(--border);
    border-radius: 999px;
    overflow: hidden;
}
.pw-strength-fill {
    height: 100%;
    border-radius: 999px;
    transition: width .3s ease, background-color .3s ease;
    width: 0%;
}
.pw-strength-label {
    font-size: .75rem;
    font-weight: 700;
    min-width: 50px;
    text-align: right;
}
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Show/hide password ────────────────────────────────────
        function toggleField(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-icon', 'lucide:eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-icon', 'lucide:eye');
            }
        }

        // ── Password strength meter ───────────────────────────────
        function checkStrength(value) {
            const wrap  = document.getElementById('strengthWrap');
            const fill  = document.getElementById('strengthFill');
            const label = document.getElementById('strengthLabel');

            if (!value) {
                wrap.style.display = 'none';
                return;
            }

            wrap.style.display = 'flex';

            let score = 0;
            if (value.length >= 8)                        score++;
            if (/[A-Z]/.test(value))                      score++;
            if (/[0-9]/.test(value))                      score++;
            if (/[^A-Za-z0-9]/.test(value))               score++;

            const levels = [
                { pct: '25%', color: '#DC2626', text: 'Weak'   },
                { pct: '50%', color: '#F97316', text: 'Fair'   },
                { pct: '75%', color: '#EAB308', text: 'Good'   },
                { pct: '100%',color: '#16a34a', text: 'Strong' },
            ];

            const lvl = levels[score - 1] ?? levels[0];
            fill.style.width           = lvl.pct;
            fill.style.backgroundColor = lvl.color;
            label.textContent          = lvl.text;
            label.style.color          = lvl.color;
        }
    </script>
}
