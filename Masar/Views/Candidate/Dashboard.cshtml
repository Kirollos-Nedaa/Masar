@using Masar.Domain.ViewModels.CandidateDtos
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["HasSidebar"] = true;
}
@model CandidateDashboardDto

@section Sidebar {
    <partial name="_CandidateSidebar" />
}

@* ── Page header ──────────────────────────────────────────── *@
<div class="page-header">
    <h1 class="page-title">Welcome back, @Model.Name.ToUpper()!</h1>
    <p class="page-subtitle">Here's what's happening with your job search</p>
</div>

@* ── Profile completion banner ────────────────────────────── *@
@if (Model.ProfileCompletion < 100)
{
    <div class="app-card mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div class="fw-bold mb-1" style="color:var(--dark);">Complete Your Profile</div>
                <div class="text-muted" style="font-size:.85rem;">
                    @Model.ProfileCompletion% complete - Add the following to complete:
                </div>
            </div>

            <a asp-controller="Candidate" asp-action="Profile" class="btn-outline-app ms-3 text-nowrap">
                Complete Profile <span class="iconify" data-icon="lucide:arrow-right" style="font-size: 1.2rem;"></span>
            </a>
        </div>

        <div class="app-progress-wrap">
            <div class="app-progress-bar" style="width:@Model.ProfileCompletion%"></div>
        </div>

        @* ── Missing Hints Section ───────────────────────────── *@
        @if (Model.ProfileHints != null && Model.ProfileHints.Any())
        {
            <div class="mt-3">
                <ul class="mb-0" style="padding-left: 18px; font-size:.85rem;">
                    @foreach (var hint in Model.ProfileHints)
                    {
                        <li class="text-muted">@hint</li>
                    }
                </ul>
            </div>
        }
    </div>
}

@* ── Stats ────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Applications</div>
                <div class="stat-card-value">@Model.TotalApplications</div>
            </div>
            <div class="stat-card-icon stat-icon-blue">
                <span class="iconify stat-icon" data-icon="lucide:file-text"></span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Saved Jobs</div>
                <div class="stat-card-value">@Model.SavedJobs</div>
            </div>
            <div class="stat-card-icon stat-icon-orange">
                <span class="iconify stat-icon" data-icon="lucide:bookmark"></span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Under Review</div>
                <div class="stat-card-value">@Model.UnderReview</div>
            </div>
            <div class="stat-card-icon stat-icon-green">
                <span class="iconify stat-icon" data-icon="lucide:clock-alert"></span>
            </div>
        </div>
    </div>
</div>

@* ── Recent Applications ──────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Recent Applications</div>
        <a asp-controller="Candidate" asp-action="Applications" class="card-view-all">
            View All <span class="iconify" data-icon="lucide:arrow-right"></span>
        </a>
    </div>

    @if (Model.RecentApplications.Any())
    {
        foreach (var app in Model.RecentApplications)
        {
            string badgeClass = app.Status switch
            {
                "Under Review" => "badge-review",
                "Applied" => "badge-applied",
                "Accepted" => "badge-accepted",
                _ => "badge-rejected"
            };

            <div class="app-row">
                <div>
                    <div class="app-row-title">@app.JobTitle</div>
                    <div class="app-row-meta">@app.Company &bull; Applied @app.AppliedDate</div>
                </div>
                <span class="status-badge @badgeClass">@app.Status</span>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4">
            <p class="text-muted text-center p-3">You haven't applied to any jobs yet.</p>
        </div>
    }
</div>

@* ── Recommended Jobs ─────────────────────────────────────── *@
@if (Model.RecommendedJobs.Any())
{
    <div class="card-section-title mb-3">Recommended for You</div>
    <div class="row g-3">
        @foreach (var job in Model.RecommendedJobs)
        {
        <div class="col-12 col-md-4">
            <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="job-card">
                <div class="job-card-title">@job.Title</div>
                <div class="job-card-company">@job.Company</div>
                <div class="job-card-meta">
                        <span><span class="iconify" data-icon="lucide:map-pin"></span> @job.Location</span>
                        <span><span class="iconify" data-icon="lucide:clock"></span> @job.PostedDate</span>
                    @if (!string.IsNullOrEmpty(job.Salary))
                    {
                            <span><span class="iconify" data-icon="lucide:dollar-sign"></span> @job.Salary</span>
                    }
                </div>
                <div class="job-card-desc">@job.Description</div>
                <span class="job-type-tag">@job.Type</span>
            </a>
        </div>
        }
    </div>
}
else
{
    <div class="app-card mb-4">
        <div class="card-section-header">
            <div class="card-section-title">Recommended for You</div>
        </div>
        <div class="text-center py-4">
            <p class="text-muted">No jobs are available at the moment.</p>
        </div>
    </div>
}
