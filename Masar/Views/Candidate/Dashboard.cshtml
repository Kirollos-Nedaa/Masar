@{
    ViewData["Title"]      = "Dashboard";
    ViewData["HasSidebar"] = true;

    // Safe ViewBag reads — avoids dynamic cast errors
    var userName    = ViewBag.UserName          != null ? (string)ViewBag.UserName          : "Joe";
    var profilePct  = ViewBag.ProfileCompletion != null ? (int)ViewBag.ProfileCompletion    : 50;
    var totalApps   = ViewBag.TotalApplications != null ? (int)ViewBag.TotalApplications    : 12;
    var savedJobs   = ViewBag.SavedJobs         != null ? (int)ViewBag.SavedJobs            : 8;
    var underReview = ViewBag.UnderReview       != null ? (int)ViewBag.UnderReview          : 5;
}

@section Sidebar {
    <partial name="_CandidateSidebar" />
}

@* ── Page header ──────────────────────────────────────────── *@
<div class="page-header">
    <h1 class="page-title">Welcome back, @(User.Identity.Name?.ToUpper() ?? "U")!</h1>
    <p class="page-subtitle">Here's what's happening with your job search</p>
</div>

@* ── Profile completion banner ────────────────────────────── *@
@if (profilePct < 100)
{
    <div class="app-card mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div class="fw-semibold mb-1" style="color:var(--dark);">Complete Your Profile</div>
                <div class="text-muted" style="font-size:.85rem;">
                    @profilePct% complete — add your skills and resume to stand out
                </div>
            </div>
            <a asp-controller="Candidate" asp-action="Profile" class="btn-outline-app ms-3 text-nowrap">
                Complete Profile <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="app-progress-wrap">
            <div class="app-progress-bar" style="width:@profilePct%"></div>
        </div>
    </div>
}

@* ── Stats ────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Applications</div>
                <div class="stat-card-value">@totalApps</div>
            </div>
            <div class="stat-card-icon stat-icon-blue">
                <i class="bi bi-file-earmark-text"></i>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Saved Jobs</div>
                <div class="stat-card-value">@savedJobs</div>
            </div>
            <div class="stat-card-icon stat-icon-orange">
                <i class="bi bi-bookmark"></i>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="stat-card">
            <div>
                <div class="stat-card-label">Under Review</div>
                <div class="stat-card-value">@underReview</div>
            </div>
            <div class="stat-card-icon stat-icon-green">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
        </div>
    </div>
</div>

@* ── Recent Applications ──────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Recent Applications</div>
        <a asp-controller="Candidate" asp-action="Applications" class="card-view-all">
            View All <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    @if (ViewBag.RecentApplications != null)
    {
        foreach (var app in ViewBag.RecentApplications)
        {
            <div class="app-row">
                <div>
                    <div class="app-row-title">@app.JobTitle</div>
                    <div class="app-row-meta">@app.Company &bull; Applied @app.AppliedDate</div>
                </div>
                @{
                    string badgeClass;
                    if (app.Status == "Under Review")      badgeClass = "badge-review";
                    else if (app.Status == "Applied")      badgeClass = "badge-applied";
                    else if (app.Status == "Accepted")     badgeClass = "badge-accepted";
                    else                                   badgeClass = "badge-rejected";
                }
                <span class="status-badge @badgeClass">@app.Status</span>
            </div>
        }
    }
    else
    {
        @* Placeholder rows shown when no real data is wired yet *@
        <div class="app-row">
            <div>
                <div class="app-row-title">Software Engineer Intern</div>
                <div class="app-row-meta">Google &bull; Applied 2 days ago</div>
            </div>
            <span class="status-badge badge-review">Under Review</span>
        </div>
        <div class="app-row">
            <div>
                <div class="app-row-title">Product Manager Intern</div>
                <div class="app-row-meta">Microsoft &bull; Applied 5 days ago</div>
            </div>
            <span class="status-badge badge-applied">Applied</span>
        </div>
        <div class="app-row">
            <div>
                <div class="app-row-title">Product Manager Intern</div>
                <div class="app-row-meta">Microsoft &bull; Applied 5 days ago</div>
            </div>
            <span class="status-badge badge-accepted">Accepted</span>
        </div>
        <div class="app-row">
            <div>
                <div class="app-row-title">Data Analyst</div>
                <div class="app-row-meta">Amazon &bull; Applied 1 week ago</div>
            </div>
            <span class="status-badge badge-rejected">Rejected</span>
        </div>
    }
</div>

@* ── Recommended Jobs ─────────────────────────────────────── *@
<div class="card-section-title mb-3">Recommended for You</div>

<div class="row g-3">
    @if (ViewBag.RecommendedJobs != null)
    {
        foreach (var job in ViewBag.RecommendedJobs)
        {
            <div class="col-12 col-md-6">
                <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="job-card">
                    <div class="job-card-title">@job.Title</div>
                    <div class="job-card-company">@job.Company</div>
                    <div class="job-card-meta">
                        <span><i class="bi bi-geo-alt"></i> @job.Location</span>
                        <span><i class="bi bi-clock"></i> @job.PostedDate</span>
                        @if (!string.IsNullOrEmpty(job.Salary))
                        {
                            <span><i class="bi bi-currency-dollar"></i> @job.Salary</span>
                        }
                    </div>
                    <div class="job-card-desc">@job.Description</div>
                    <span class="job-type-tag">@job.Type</span>
                </a>
            </div>
        }
    }
    else
    {
        @* Placeholder cards shown until real data is wired *@
        <div class="col-12 col-md-4">
            <a href="#" class="job-card">
                <div class="job-card-title">Frontend Developer Intern</div>
                <div class="job-card-company">TechCorp</div>
                <div class="job-card-meta">
                    <span><i class="bi bi-geo-alt"></i> San Francisco, CA</span>
                    <span><i class="bi bi-clock"></i> 2 days ago</span>
                    <span><i class="bi bi-currency-dollar"></i> $25–35/hr</span>
                </div>
                <div class="job-card-desc">
                    Join our team as a frontend developer intern and work on cutting-edge web applications.
                </div>
                <span class="job-type-tag">Internship</span>
            </a>
        </div>
        <div class="col-12 col-md-4">
            <a href="#" class="job-card">
                <div class="job-card-title">UX Design Intern</div>
                <div class="job-card-company">DesignCo</div>
                <div class="job-card-meta">
                    <span><i class="bi bi-geo-alt"></i> Remote</span>
                    <span><i class="bi bi-clock"></i> 1 week ago</span>
                    <span><i class="bi bi-currency-dollar"></i> $20–30/hr</span>
                </div>
                <div class="job-card-desc">
                    Help design beautiful user experiences for our mobile and web applications.
                </div>
                <span class="job-type-tag">Internship</span>
            </a>
        </div>
        <div class="col-12 col-md-4">
            <a href="#" class="job-card">
                <div class="job-card-title">UX Design Intern</div>
                <div class="job-card-company">DesignCo</div>
                <div class="job-card-meta">
                    <span><i class="bi bi-geo-alt"></i> Remote</span>
                    <span><i class="bi bi-clock"></i> 1 week ago</span>
                    <span><i class="bi bi-currency-dollar"></i> $20–30/hr</span>
                </div>
                <div class="job-card-desc">
                    Help design beautiful user experiences for our mobile and web applications.
                </div>
                <span class="job-type-tag">Internship</span>
            </a>
        </div>
    }
</div>
