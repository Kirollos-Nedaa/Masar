@model Masar.Domain.ViewModels.CandidateDtos.CandidateProfileDto

@{
    ViewData["Title"] = "My Profile";
    ViewData["HasSidebar"] = true;
}

@section Sidebar {
    <partial name="_CandidateSidebar" />
}

@* ── Page Header ──────────────────────────────────────────── *@
<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1 class="page-title">My Profile</h1>
        <p class="page-subtitle">Your professional information visible to companies</p>
    </div>
</div>

@* ── Personal Information ─────────────────────────────────── *@
@functions {
    string MissingLabel(bool condition) => condition ? "field-missing-label" : "";
    string MissingValue(bool condition) => condition ? "field-missing-value" : "";
    string DisplayOrDefault(string value) => string.IsNullOrWhiteSpace(value) ? "Not provided" : value;
}

<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Personal Information</div>
        <a asp-controller="Candidate" asp-action="EditPersonalInfo" class="btn-edit-section">
            <span class="iconify" data-icon="lucide:square-pen"></span> Edit
        </a>
    </div>

    @* Row 1 — First Name, Last Name *@
    <div class="row g-3 mb-3">
        @{
            var firstMissing = string.IsNullOrWhiteSpace(Model.FirstName);
            var lastMissing = string.IsNullOrWhiteSpace(Model.LastName);
        }

        <div class="col-12 col-sm-6">
            <div class="profile-field-label @MissingLabel(firstMissing)">First Name</div>
            <div class="profile-field-value @MissingValue(firstMissing)">
                @DisplayOrDefault(Model.FirstName)
            </div>
        </div>

        <div class="col-12 col-sm-6">
            <div class="profile-field-label @MissingLabel(lastMissing)">Last Name</div>
            <div class="profile-field-value @MissingValue(lastMissing)">
                @DisplayOrDefault(Model.LastName)
            </div>
        </div>
    </div>

    @* Row 2 — Gender, Location, Date of Birth *@
    <div class="row g-3 mb-3">
        @{
            var genderMissing = !Model.Gender.HasValue;
            var locationMissing = string.IsNullOrWhiteSpace(Model.Location);
            var dobMissing = !Model.DateOfBirth.HasValue;
        }

        <div class="col-12 col-sm-4">
            <div class="profile-field-label @MissingLabel(genderMissing)">Gender</div>
            <div class="profile-field-value @MissingValue(genderMissing)">
                @(Model.Gender?.ToString() ?? "Not provided")
            </div>
        </div>

        <div class="col-12 col-sm-4">
            <div class="profile-field-label @MissingLabel(locationMissing)">Location</div>
            <div class="profile-field-value @MissingValue(locationMissing)">
                @DisplayOrDefault(Model.Location)
            </div>
        </div>

        <div class="col-12 col-sm-4">
            <div class="profile-field-label @MissingLabel(dobMissing)">Date of Birth</div>
            <div class="profile-field-value @MissingValue(dobMissing)">
                @(Model.DateOfBirth?.ToString("MMMM dd, yyyy") ?? "Not provided")
            </div>
        </div>
    </div>

    @* Row 3 — Email, Phone *@
    <div class="row g-3 mb-3">
        @{
            var emailMissing = string.IsNullOrWhiteSpace(Model.Email);
            var phoneMissing = string.IsNullOrWhiteSpace(Model.PhoneNumber);
        }

        <div class="col-12 col-sm-6">
            <div class="profile-field-label @MissingLabel(emailMissing)">Email</div>
            <div class="profile-field-value @MissingValue(emailMissing)">
                @DisplayOrDefault(Model.Email)
            </div>
        </div>

        <div class="col-12 col-sm-6">
            <div class="profile-field-label @MissingLabel(phoneMissing)">Phone Number</div>
            <div class="profile-field-value @MissingValue(phoneMissing)">
                @DisplayOrDefault(Model.PhoneNumber)
            </div>
        </div>
    </div>

    @* Row 4 — Bio *@
    <div class="row g-3">
        @{
            var bioMissing = string.IsNullOrWhiteSpace(Model.Bio);
        }

        <div class="col-12">
            <div class="profile-field-label @MissingLabel(bioMissing)">Bio</div>
            <div class="profile-field-value @MissingValue(bioMissing)">
                @(string.IsNullOrWhiteSpace(Model.Bio) ? "No bio added yet." : Model.Bio)
            </div>
        </div>
    </div>
</div>

@* ── Education ────────────────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Education</div>
        <a asp-controller="Candidate" asp-action="EditEducation" class="btn-edit-section">
            <span class="iconify" data-icon="lucide:square-pen"></span> Edit
        </a>
    </div>

    @if (Model.Education != null)
    {
        <div class="education-block">
            <div class="education-icon">
                <span class="iconify" data-icon="lucide:graduation-cap"></span>
            </div>
            <div class="education-details">
                <div class="education-university">@Model.Education.University</div>
                <div class="education-degree">
                    @Model.Education.Degree
                    @if (!string.IsNullOrEmpty(Model.Education.Major))
                    {
                        <span class="text-muted"> &mdash; @Model.Education.Major</span>
                    }
                </div>
                <div class="education-years text-muted" style="font-size:.82rem; margin-top:.25rem;">
                    @if (Model.Education.StartYear.HasValue)
                    {
                        @Model.Education.StartYear.Value.ToString("MM/yyyy")
                    }
                    @if (Model.Education.ExpectedGraduation.HasValue)
                    {
                        <span> &ndash; @Model.Education.ExpectedGraduation.Value.ToString("MM/yyyy")</span>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted mb-0">No education added yet.</p>
    }
</div>

@* ── Skills ───────────────────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Skills</div>
        <a asp-controller="Candidate" asp-action="EditSkills" class="btn-edit-section">
            <span class="iconify" data-icon="lucide:settings-2"></span> Manage Skills
        </a>
    </div>

    @if (Model.SkillNames.Any())
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var skill in Model.SkillNames)
            {
                <span class="skill-badge">@skill</span>
            }
        </div>
    }
    else
    {
        <p class="text-muted mb-0">No skills added yet.
            <a asp-controller="Candidate" asp-action="EditSkills">Add your first skill</a>
        </p>
    }
</div>

@* ── Resume ───────────────────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Resume</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ResumeUrl))
    {
        <div class="resume-row">
            <span class="iconify resume-icon" data-icon="lucide:file-text"></span>
            <div class="resume-info">
                <div class="resume-name">resume.pdf</div>
                <div class="resume-meta text-muted">Uploaded</div>
            </div>
            <a href="@Model.ResumeUrl" target="_blank" class="btn-outline-app btn-sm-app">
                <span class="iconify" data-icon="lucide:eye"></span> View
            </a>
        </div>
    }
    else
    {
        <div class="resume-upload-zone">
            <span class="iconify resume-upload-icon" data-icon="lucide:upload"></span>
            <p class="mb-1">Drop your resume here or click to browse</p>
            <p class="text-muted mb-3" style="font-size:.82rem;">PDF, DOC, DOCX (max 5MB)</p>
            <button type="button" class="btn-primary-app btn-sm-app">
                <span class="iconify" data-icon="lucide:upload"></span> Upload Resume
            </button>
        </div>
    }
</div>

@* ── Professional Links ───────────────────────────────────── *@
<div class="app-card mb-4">
    <div class="card-section-header">
        <div class="card-section-title">Professional Links</div>
        <a asp-controller="Candidate" asp-action="EditLinks" class="btn-edit-section">
            <span class="iconify" data-icon="lucide:settings-2"></span> Manage Links
        </a>
    </div>

    @if (Model.ProfessionalLinks.Any())
    {
        <div>
            @foreach (var link in Model.ProfessionalLinks)
            {
                string icon = (int)link.LinkName switch
                {
                    1 => "simple-icons:linkedin",
                    2 => "simple-icons:github",
                    3 => "lucide:globe",
                    _ => "lucide:link"
                };
                string color = (int)link.LinkName switch
                {
                    1 => "#0A66C2",
                    2 => "#24292E",
                    3 => "#2563EB",
                    _ => "#64748B"
                };
                string label = (int)link.LinkName switch
                {
                    1 => "LinkedIn",
                    2 => "GitHub",
                    3 => "Portfolio",
                    _ => "Other"
                };

                <div class="saved-link-row">
                    <div class="saved-link-icon-wrap">
                        <span class="iconify"
                              data-icon="@icon"
                              style="color:@color;width:1.1rem;height:1.1rem;"></span>
                    </div>
                    <span class="saved-link-name">@label</span>
                    <a href="@link.Url" target="_blank" class="saved-link-url">@link.Url</a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-3">
            <span class="iconify"
                  data-icon="lucide:link"
                  style="width:2rem;height:2rem;color:var(--border);display:block;margin:0 auto .5rem;"></span>
            <p class="text-muted mb-2" style="font-size:.875rem;">No links added yet.</p>
        </div>
    }
</div>