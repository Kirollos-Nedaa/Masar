@using Masar.Domain.ViewModels.CandidateDtos
@model List<SavedJobDto>

@{
    ViewData["Title"] = "Saved Jobs";
    ViewData["HasSidebar"] = true;
}

@section Sidebar {
    <partial name="_CandidateSidebar" />
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title">Saved Jobs</h1>
        <p class="page-subtitle">Jobs you've bookmarked to review later</p>
    </div>
    <a asp-controller="Jobs" asp-action="Index" class="btn-primary-app">
        <span class="iconify" data-icon="lucide:search"></span> Find More Jobs
    </a>
</div>

<div class="app-card">
    <div class="card-section-header mb-3">
        <div class="card-section-title">Saved Jobs</div>
        @if (Model.Any())
        {
            <span class="text-muted" style="font-size:.8rem;">
                @Model.Count job@(Model.Count != 1 ? "s" : "")
            </span>
        }
    </div>

    @if (Model.Any())
    {
        foreach (var job in Model)
        {
            var initials = job.CompanyName.Length > 0
                ? job.CompanyName.Substring(0, Math.Min(2, job.CompanyName.Length)).ToUpper()
                : "?";

            <div class="saved-item">
                <div class="saved-item-logo">
                    @if (!string.IsNullOrEmpty(job.CompanyLogo))
                    {
                        <img src="@job.CompanyLogo" alt="@job.CompanyName" />
                    }
                    else
                    {
                        @initials
                    }
                </div>

                <div class="saved-item-body">
                    <div class="saved-item-title-row">
                        <a asp-controller="Jobs" asp-action="Details"
                           asp-route-id="@job.JobId"
                           class="saved-item-title">@job.JobTitle</a>

                        @if (!job.IsActive)
                        {
                            <span class="status-badge badge-rejected" style="font-size:.7rem;">Closed</span>
                        }
                    </div>
                    <div class="saved-item-meta">
                        <span>
                            <span class="iconify" data-icon="lucide:building-2"></span>
                            @job.CompanyName
                        </span>
                        <span>
                            <span class="iconify" data-icon="lucide:map-pin"></span>
                            @job.Location
                        </span>
                        <span>
                            <span class="iconify" data-icon="lucide:briefcase"></span>
                            @job.JobType
                        </span>
                        @if (!string.IsNullOrEmpty(job.SalaryDisplay))
                        {
                            <span>
                                <span class="iconify" data-icon="lucide:dollar-sign"></span>
                                @job.SalaryDisplay
                            </span>
                        }
                        <span>
                            <span class="iconify" data-icon="lucide:clock"></span>
                            @job.PostedDateDisplay
                        </span>
                    </div>
                </div>

                <div class="saved-item-actions">
                    @if (job.IsActive)
                    {
                        <a asp-controller="Candidate" asp-action="Apply"
                           asp-route-jobId="@job.JobId"
                           class="btn-primary-app btn-sm-app">
                            Apply
                        </a>
                    }

                    <form asp-controller="Candidate" asp-action="ToggleSaveJob"
                          method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="jobId" value="@job.JobId" />
                        <input type="hidden" name="returnUrl"
                               value="@Url.Action("SavedJobs", "Candidate")" />
                        <button type="submit" class="btn-icon-danger" title="Remove">
                            <span class="iconify" data-icon="lucide:bookmark-x"></span>
                        </button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <span class="iconify" style="font-size:3rem;color:var(--border);display:block;margin:0 auto .75rem;"
                  data-icon="lucide:bookmark-x"></span>
            <p class="text-muted mb-3">You haven't saved any jobs yet.</p>
            <a asp-controller="Jobs" asp-action="Index" class="btn-primary-app">
                <span class="iconify" data-icon="lucide:search"></span> Browse Jobs
            </a>
        </div>
    }
</div>

@section Styles {
<style>
.saved-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.1rem 0; border-bottom: 1px solid var(--border);
}
.saved-item:last-child { border-bottom: none; }

.saved-item-logo {
    width: 44px; height: 44px; border-radius: var(--radius-md);
    background: var(--blue-50); border: 1px solid var(--blue-100);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Sora', sans-serif; font-size: .85rem;
    font-weight: 700; color: var(--blue); flex-shrink: 0; overflow: hidden;
}
.saved-item-logo img { width: 100%; height: 100%; object-fit: cover; }

.saved-item-body { flex: 1; min-width: 0; }

.saved-item-title-row {
    display: flex; align-items: center; gap: .5rem; margin-bottom: .3rem;
}

.saved-item-title {
    font-size: .9375rem; font-weight: 700; color: var(--dark);
    text-decoration: none; transition: color .15s;
}
.saved-item-title:hover { color: var(--blue); }

.saved-item-meta {
    display: flex; flex-wrap: wrap; gap: .25rem .875rem;
    font-size: .8rem; color: var(--muted);
}
.saved-item-meta span { display: inline-flex; align-items: center; gap: .3rem; }

.saved-item-actions {
    display: flex; align-items: center; gap: .5rem; flex-shrink: 0;
}
</style>
}
