@model Masar.Domain.ViewModels.CompanyDtos.CompanyJobsViewDto

@{
    ViewData["Title"] = "All Postings";
    ViewData["HasSidebar"] = true;
}

@section Sidebar {
    <partial name="_CompanySidebar" />
}

@* Page Header *@
<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title">All Postings</h1>
        <p class="page-subtitle">Manage all your job and internship postings</p>
    </div>
    <a asp-controller="Company" asp-action="PostJob" class="btn-primary-app">
        <span class="iconify" data-icon="lucide:plus-circle"></span> Post New Job
    </a>
</div>

@* Jobs Table *@
<div class="app-card">
    @if (Model.Jobs.Any())
    {
        <div class="table-responsive">
            <table class="company-table">
                <thead>
                    <tr>
                        <th>Job Title</th>
                        <th>Status</th>
                        <th>Applicants</th>
                        <th>Deadline</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.Jobs)
                    {
                        var statusClass = job.IsActive ? "badge-accepted" : "badge-rejected";
                        var statusLabel = job.IsActive ? "Active" : "Closed";
                        var deadlinePast = job.IsExpired;

                        <tr>
                            <td>
                                <div class="job-table-title">@job.Title</div>
                            </td>
                            <td>
                                <span class="status-badge @statusClass">@statusLabel</span>
                                @if (deadlinePast && job.IsActive)
                                {
                                    <div style="font-size:.7rem;color:var(--red);margin-top:.2rem;">Deadline passed</div>
                                }
                            </td>
                            <td>
                                <div class="applicant-count">
                                    <span class="iconify" data-icon="lucide:users"></span>
                                    @job.ApplicantCount
                                </div>
                            </td>
                            <td class="table-meta-text">
                                @job.ApplicationDeadline.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <a asp-controller="Company"
                                       asp-action="Applicants"
                                       asp-route-jobId="@job.Id"
                                       class="btn-table-action">
                                        <span class="iconify" data-icon="lucide:users"></span>
                                        Applicants
                                    </a>
                                    <a asp-controller="Company"
                                       asp-action="EditJob"
                                       asp-route-id="@job.Id"
                                       class="btn-table-action btn-table-ghost"
                                       title="Edit">
                                        <span class="iconify" data-icon="lucide:pencil"></span>
                                    </a>
                                    <form asp-controller="Company"
                                          asp-action="ToggleJobStatus"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit"
                                                class="btn-table-action btn-table-ghost"
                                                title="@(job.IsActive ? "Close" : "Reopen")">
                                            <span class="iconify"
                                                  data-icon="@(job.IsActive ? "lucide:archive" : "lucide:refresh-cw")"></span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            var startItem = ((Model.Page - 1) * Model.PageSize) + 1;
            var endItem = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);

            <div class="app-pagination-bar">
                <div class="app-pagination-summary">
                    Showing @startItem-@endItem of @Model.TotalCount postings
                </div>

                <div class="app-pagination">
                    <a asp-action="Jobs"
                       asp-controller="Company"
                       asp-route-page="@(Model.Page - 1)"
                       class="app-page-btn @(Model.HasPreviousPage ? string.Empty : "disabled")">
                        Previous
                    </a>

                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Jobs"
                           asp-controller="Company"
                           asp-route-page="@p"
                           class="app-page-btn @(p == Model.Page ? "active" : string.Empty)">
                            @p
                        </a>
                    }

                    <a asp-action="Jobs"
                       asp-controller="Company"
                       asp-route-page="@(Model.Page + 1)"
                       class="app-page-btn @(Model.HasNextPage ? string.Empty : "disabled")">
                        Next
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <span class="iconify" style="font-size:3rem;color:var(--border);display:block;margin:0 auto .75rem;"
                  data-icon="lucide:briefcase"></span>
            <p class="text-muted mb-3">You haven't posted any jobs yet.</p>
            <a asp-controller="Company" asp-action="PostJob" class="btn-primary-app">
                <span class="iconify" data-icon="lucide:plus-circle"></span>
                Post Your First Job
            </a>
        </div>
    }
</div>
