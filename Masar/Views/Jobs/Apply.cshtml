@using Masar.Domain.ViewModels.CandidateDtos
@using Masar.Domain.ViewModels.JobDtos
@model ApplyJobViewDto

@{
    ViewData["Title"] = "Apply for Position";
    var job = Model.Job;
    var f = Model.Form;
}

@section Styles {
    <style>
        .apply-wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        .apply-back-link {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-size: .875rem;
            font-weight: 600;
            color: var(--blue);
            text-decoration: none;
            margin-bottom: 1.5rem;
        }

            .apply-back-link:hover {
                text-decoration: underline;
            }

        .apply-page-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--dark);
            letter-spacing: -.02em;
            margin-bottom: .35rem;
        }

        .apply-page-sub {
            color: var(--muted);
            font-size: .9rem;
            margin-bottom: 1.75rem;
        }

        /* ── Job summary card ────────────────────────────────────── */
        .apply-job-summary {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .apply-job-logo {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-md);
            background: var(--blue-50);
            border: 1px solid var(--blue-100);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sora', sans-serif;
            font-size: .9rem;
            font-weight: 700;
            color: var(--blue);
            flex-shrink: 0;
            overflow: hidden;
        }

            .apply-job-logo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .apply-job-title {
            font-family: 'Sora', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: .2rem;
        }

        .apply-job-company {
            font-size: .875rem;
            color: var(--muted);
            font-weight: 500;
            margin-bottom: .4rem;
        }

        .apply-job-meta {
            display: flex;
            flex-wrap: wrap;
            gap: .3rem .875rem;
            font-size: .8rem;
            color: var(--muted);
        }

            .apply-job-meta span {
                display: inline-flex;
                align-items: center;
                gap: .3rem;
            }

        /* ── Section cards ───────────────────────────────────────── */
        .apply-section {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .apply-section-title {
            font-family: 'Sora', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 1.25rem;
            padding-bottom: .75rem;
            border-bottom: 1px solid var(--border);
        }

        /* ── Resume options ──────────────────────────────────────── */
        .resume-option {
            display: flex;
            align-items: center;
            gap: .625rem;
            font-size: .9rem;
            font-weight: 500;
            color: var(--dark);
            cursor: pointer;
            margin-bottom: .625rem;
            user-select: none;
        }

            .resume-option input[type="radio"] {
                width: 16px;
                height: 16px;
                accent-color: var(--blue);
                cursor: pointer;
                flex-shrink: 0;
            }

        .resume-existing-file {
            display: flex;
            align-items: center;
            gap: .875rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: .875rem 1rem;
            margin-top: .625rem;
        }

        .resume-file-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: var(--blue-50);
            border: 1px solid var(--blue-100);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--blue);
            flex-shrink: 0;
        }

        .resume-file-name {
            font-size: .875rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: .15rem;
        }

        .resume-file-sub {
            font-size: .78rem;
            color: var(--muted);
        }

        .resume-replace-btn {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            padding: .35rem .75rem;
            font-size: .8rem;
            font-weight: 600;
            color: var(--dark);
            cursor: pointer;
            text-decoration: none;
            transition: border-color .15s;
            flex-shrink: 0;
        }

            .resume-replace-btn:hover {
                border-color: var(--blue);
                color: var(--blue);
            }

        .resume-upload-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius-md);
            padding: 2rem;
            text-align: center;
            color: var(--muted);
            margin-top: .625rem;
            cursor: pointer;
            transition: border-color .15s, background .15s;
        }

            .resume-upload-zone:hover {
                border-color: var(--blue);
                background: var(--blue-50);
            }

        .resume-hint {
            font-size: .78rem;
            color: var(--muted);
            margin-top: .625rem;
        }

        /* ── Radio group (TorF) ──────────────────────────────────── */
        .apply-radio-group {
            display: flex;
            flex-direction: column;
            gap: .375rem;
            margin-top: .4rem;
        }

        .apply-radio-label {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .9rem;
            color: var(--dark);
            cursor: pointer;
        }

            .apply-radio-label input[type="radio"] {
                width: 15px;
                height: 15px;
                accent-color: var(--blue);
                cursor: pointer;
            }

        /* ── Terms ───────────────────────────────────────────────── */
        .terms-check-label {
            display: flex;
            align-items: flex-start;
            gap: .75rem;
            cursor: pointer;
            margin-bottom: 1rem;
        }

            .terms-check-label:last-child {
                margin-bottom: 0;
            }

            .terms-check-label input[type="checkbox"] {
                width: 16px;
                height: 16px;
                accent-color: var(--blue);
                cursor: pointer;
                flex-shrink: 0;
                margin-top: 2px;
            }

        .terms-check-title {
            font-size: .875rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: .15rem;
        }

        .terms-check-sub {
            font-size: .8rem;
            color: var(--muted);
            line-height: 1.5;
        }

        /* ── Actions ─────────────────────────────────────────────── */
        .apply-actions {
            display: flex;
            justify-content: flex-end;
            gap: .75rem;
            margin-top: 1.5rem;
        }

        @@media (max-width: 600px) {
            .apply-wrap {
                padding: 1rem 1rem 3rem;
            }

            .apply-page-title {
                font-size: 1.375rem;
            }
        }
    </style>
}

<div class="apply-wrap">

    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="apply-back-link">
        <span class="iconify" data-icon="lucide:arrow-left"></span>
        Back to Job Details
    </a>

    <h1 class="apply-page-title">Apply for Position</h1>
    <p class="apply-page-sub">Complete the form below to submit your application</p>

    @* ── Job Summary ──────────────────────────────────────── *@
    <div class="apply-job-summary">
        <div class="apply-job-logo">
            @if (!string.IsNullOrEmpty(job.CompanyLogo))
            {
                <img src="@job.CompanyLogo" alt="@job.CompanyName" />
            }
            else
            {
                @(job.CompanyName.Length > 0
                    ? job.CompanyName.Substring(0, Math.Min(2, job.CompanyName.Length)).ToUpper()
                    : "?")
            }
        </div>
        <div>
            <div class="apply-job-title">@job.Title</div>
            <div class="apply-job-company">@job.CompanyName</div>
            <div class="apply-job-meta">
                <span><span class="iconify" data-icon="lucide:map-pin"></span> @job.Location</span>
                <span><span class="iconify" data-icon="lucide:briefcase"></span> @job.JobType</span>
                @if (!string.IsNullOrEmpty(job.SalaryDisplay))
                {
                    <span><span class="iconify" data-icon="lucide:dollar-sign"></span> @job.SalaryDisplay</span>
                }
            </div>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="epi-alert-error mb-4">
            <span class="iconify" data-icon="lucide:circle-alert"></span>
            @Html.ValidationSummary(false, null, new { @class = "mb-0" })
        </div>
    }

    <form asp-controller="Jobs" asp-action="Apply" asp-route-jobId="@job.Id"
          method="post" enctype="multipart/form-data" id="applyForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Form.JobId" value="@job.Id" />
        <input type="hidden" asp-for="Form.ExistingResumeUrl" />

        @* ── Section 1: Personal Information ─────────────── *@
        <div class="apply-section">
            <div class="apply-section-title">Personal Information</div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-sm-6">
                    <label class="epi-label">First Name <span style="color:var(--red)">*</span></label>
                    <input asp-for="Form.FirstName" class="epi-input" placeholder="John" />
                    <span asp-validation-for="Form.FirstName" class="epi-error"></span>
                </div>
                <div class="col-12 col-sm-6">
                    <label class="epi-label">Last Name <span style="color:var(--red)">*</span></label>
                    <input asp-for="Form.LastName" class="epi-input" placeholder="Doe" />
                    <span asp-validation-for="Form.LastName" class="epi-error"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="epi-label">Email Address <span style="color:var(--red)">*</span></label>
                <input asp-for="Form.Email" type="email" class="epi-input" placeholder="john@example.com" />
                <span asp-validation-for="Form.Email" class="epi-error"></span>
            </div>

            <div class="mb-3">
                <label class="epi-label">Phone Number</label>
                <input asp-for="Form.PhoneNumber" class="epi-input" placeholder="+1 (555) 123-4567" />
            </div>

            <div>
                <label class="epi-label">Current Location</label>
                <input asp-for="Form.Location" class="epi-input" placeholder="City, Country" />
            </div>
        </div>

        @* ── Section 2: Resume/CV (only if RequireCv) ────── *@
        @if (job.RequireCv)
        {
            <div class="apply-section">
                <div class="apply-section-title">
                    Resume/CV <span style="color:var(--red)">*</span>
                </div>

                @if (!string.IsNullOrEmpty(f.ExistingResumeUrl))
                {
                    <label class="resume-option">
                        <input type="radio" name="Form.UseExistingResume" value="true"
                               id="useExisting" checked="@f.UseExistingResume"
                               onchange="toggleResumeSection()" />
                        Use my existing resume
                    </label>
                    <label class="resume-option">
                        <input type="radio" name="Form.UseExistingResume" value="false"
                               id="uploadNew" checked="@(!f.UseExistingResume)"
                               onchange="toggleResumeSection()" />
                        Upload a new resume
                    </label>

                    <div id="existingResumePanel">
                        <div class="resume-existing-file">
                            <div class="resume-file-icon">
                                <span class="iconify" data-icon="lucide:file-text"></span>
                            </div>
                            <div>
                                <div class="resume-file-name">My Resume</div>
                                <div class="resume-file-sub">Previously uploaded</div>
                            </div>
                            <a href="@f.ExistingResumeUrl" target="_blank" class="resume-replace-btn">
                                <span class="iconify" data-icon="lucide:eye"></span> View
                            </a>
                        </div>
                    </div>

                    <div id="uploadNewPanel" style="display:none;">
                        <input type="file" name="resumeFile" id="resumeFile"
                               accept=".pdf,.doc,.docx" class="d-none" />
                        <div class="resume-upload-zone" onclick="document.getElementById('resumeFile').click()">
                            <span class="iconify" style="font-size:2rem;display:block;margin:0 auto .5rem;color:var(--border);"
                                  data-icon="lucide:upload-cloud"></span>
                            <p class="mb-1" style="font-weight:600;">Click to upload or drag and drop</p>
                            <p class="text-muted mb-0" style="font-size:.8rem;">PDF, DOC, DOCX</p>
                        </div>
                    </div>
                }
                else
                {
                    <input type="file" name="resumeFile" id="resumeFile"
                           accept=".pdf,.doc,.docx" class="d-none" />
                    <div class="resume-upload-zone" onclick="document.getElementById('resumeFile').click()">
                        <span class="iconify" style="font-size:2rem;display:block;margin:0 auto .5rem;color:var(--border);"
                              data-icon="lucide:upload-cloud"></span>
                        <p class="mb-1" style="font-weight:600;">Click to upload or drag and drop</p>
                        <p class="text-muted mb-0" style="font-size:.8rem;">PDF, DOC, DOCX</p>
                    </div>
                    <p id="resumeFileName" class="resume-hint"></p>
                }

                <p class="resume-hint">Accepted formats: PDF, DOC, DOCX (max 5MB)</p>
            </div>
        }

        @* ── Section 3: Cover Letter (only if RequireCoverLetter) *@
        @if (job.RequireCoverLetter)
        {
            <div class="apply-section">
                <div class="apply-section-title">
                    Cover Letter <span style="color:var(--red)">*</span>
                </div>

                <label class="epi-label">
                    Why are you interested in this position?
                    <span class="epi-char-count" id="clCount">0 / 2000</span>
                </label>
                <textarea asp-for="Form.CoverLetter"
                          rows="6"
                          class="epi-input epi-textarea"
                          placeholder="Tell us about your interest in this role, relevant experience, and what makes you a great fit..."
                          maxlength="2000"
                          oninput="updateCount(this, 'clCount')"></textarea>
                <span asp-validation-for="Form.CoverLetter" class="epi-error"></span>
                <p class="epi-hint">Minimum 100 characters</p>
            </div>
        }

        @* ── Section 4: Additional Questions (only if job has questions) *@
        @if (Model.Questions.Any())
        {
            <div class="apply-section">
                <div class="apply-section-title">Additional Questions</div>

                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];

                    <div class="mb-4">
                        <label class="epi-label">
                            @q.QuestionText
                            @if (q.IsRequired)
                            {
                                <span style="color:var(--red)"> *</span>
                            }
                        </label>

                        @if (q.Type == "TorF")
                        {
                            <div class="apply-radio-group">
                                <label class="apply-radio-label">
                                    <input type="radio"
                                           name="Answers[@i].Answer"
                                           value="Yes"
                                    @(q.IsRequired ? "required" : "") />
                                    Yes
                                </label>
                                <label class="apply-radio-label">
                                    <input type="radio"
                                           name="Answers[@i].Answer"
                                           value="No" />
                                    No
                                </label>
                            </div>
                        }
                        else
                        {
                            <input type="text"
                                   name="Answers[@i].Answer"
                                   class="epi-input"
                                   placeholder="Your answer..."
                            @(q.IsRequired ? "required" : "") />
                        }

                        <input type="hidden" name="Answers[@i].QuestionId" value="@q.Id" />
                    </div>
                }
            </div>
        }

        @* ── Section 5: Terms ────────────────────────────── *@
        <div class="apply-section">
            <label class="terms-check-label">
                <input asp-for="Form.AgreeToTerms" type="checkbox" data-val="false" />
                <div>
                    <div class="terms-check-title">
                        I agree to the terms and conditions
                        <span style="color:var(--red)"> *</span>
                    </div>
                    <div class="terms-check-sub">
                        By submitting this application, I confirm that the information provided is accurate and complete.
                    </div>
                </div>
            </label>
            <span asp-validation-for="Form.AgreeToTerms" class="epi-error"></span>

            <label class="terms-check-label mt-2">
                <input asp-for="Form.ConsentToDataProcessing" type="checkbox" data-val="false" />
                <div>
                    <div class="terms-check-title">
                        I consent to data processing
                        <span style="color:var(--red)"> *</span>
                    </div>
                    <div class="terms-check-sub">
                        I understand that my personal data will be processed according to the company's privacy policy.
                    </div>
                </div>
            </label>
            <span asp-validation-for="Form.ConsentToDataProcessing" class="epi-error"></span>
        </div>

        @* ── Actions ──────────────────────────────────────── *@
        <div class="apply-actions">
            <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id"
               class="btn-outline-app">
                Cancel
            </a>
            <button type="submit" class="btn-primary-app">
                <span class="iconify" data-icon="lucide:send"></span>
                Submit Application
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateCount(el, id) {
            document.getElementById(id).textContent = `${el.value.length} / ${el.maxLength}`;
        }

        function toggleResumeSection() {
            const useExisting = document.getElementById('useExisting')?.checked;
            const existingPanel = document.getElementById('existingResumePanel');
            const uploadPanel   = document.getElementById('uploadNewPanel');
            if (existingPanel) existingPanel.style.display = useExisting ? 'block' : 'none';
            if (uploadPanel)   uploadPanel.style.display   = useExisting ? 'none'  : 'block';
        }

        // Show file name when upload selected
        document.getElementById('resumeFile')?.addEventListener('change', function () {
            const nameEl = document.getElementById('resumeFileName');
            if (nameEl && this.files[0]) {
                nameEl.textContent = `Selected: ${this.files[0].name}`;
            }
        });

        window.addEventListener('DOMContentLoaded', () => {
            const cl = document.querySelector('textarea[name="Form.CoverLetter"]');
            if (cl) updateCount(cl, 'clCount');
        });
    </script>
}
