@using Masar.Domain.ViewModels.JobDtos
@model JobDetailDto

@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <style>
        .job-detail-wrap {
            max-width: 820px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        .job-back-link {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-size: .875rem;
            font-weight: 600;
            color: var(--blue);
            text-decoration: none;
            margin-bottom: 1.5rem;
        }

        .job-back-link:hover { text-decoration: underline; }

        /* ── Header card ─────────────────────────────────────────── */
        .job-header-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .job-header-top {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .job-header-logo {
            width: 56px;
            height: 56px;
            border-radius: var(--radius-md);
            background: var(--blue-50);
            border: 1px solid var(--blue-100);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sora', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--blue);
            flex-shrink: 0;
            overflow: hidden;
        }

        .job-header-logo img { width: 100%; height: 100%; object-fit: cover; }

        .job-header-info { flex: 1; min-width: 0; }

        .job-header-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark);
            letter-spacing: -.02em;
            margin-bottom: .25rem;
            line-height: 1.2;
        }

        .job-header-company {
            font-size: .9375rem;
            color: var(--muted);
            font-weight: 500;
        }

        .job-header-actions {
            display: flex;
            gap: .5rem;
            flex-shrink: 0;
        }

        .btn-icon-action {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: var(--white);
            border: 1.5px solid var(--border);
            color: var(--muted);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            transition: border-color .15s, color .15s, background .15s;
            text-decoration: none;
        }

        .btn-icon-action:hover, .btn-icon-action.saved {
            border-color: var(--blue);
            color: var(--blue);
            background: var(--blue-50);
        }

        .job-header-meta {
            display: flex;
            flex-wrap: wrap;
            gap: .4rem 1.25rem;
            font-size: .8375rem;
            color: var(--muted);
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .job-header-meta span {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
        }

        .job-header-tags {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            margin-bottom: 1.25rem;
        }

        .job-header-tag {
            display: inline-flex;
            align-items: center;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: .275rem .75rem;
            font-size: .8rem;
            font-weight: 600;
            color: var(--muted);
        }

        .btn-apply {
            display: block;
            width: 100%;
            background: var(--blue);
            color: var(--white);
            border: none;
            border-radius: var(--radius-md);
            padding: .8rem 1.5rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: background .15s;
            text-align: center;
            text-decoration: none;
            letter-spacing: .01em;
        }

        .btn-apply:hover { background: var(--blue-hover); color: var(--white); }

        .btn-apply.applied {
            background: #DCFCE7;
            color: var(--green-dark);
            cursor: default;
        }

        /* ── Section cards ───────────────────────────────────────── */
        .job-section-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .job-section-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 1rem;
        }

        .job-section-body {
            font-size: .9rem;
            color: var(--dark);
            line-height: 1.75;
            white-space: pre-wrap;
        }

        /* ── About Company ───────────────────────────────────────── */
        .company-meta-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1.25rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }

        .company-meta-item-label {
            font-size: .78rem;
            color: var(--muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: .25rem;
        }

        .company-meta-item-value {
            font-size: .9rem;
            font-weight: 700;
            color: var(--dark);
        }

        @@media (max-width: 600px) {
            .job-detail-wrap { padding: 1rem 1rem 3rem; }
            .job-header-title { font-size: 1.25rem; }
            .company-meta-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="job-detail-wrap">

    @* Back link *@
    <a asp-controller="Jobs" asp-action="Index" class="job-back-link">
        <span class="iconify" data-icon="lucide:arrow-left"></span>
        Back to Jobs
    </a>

    @* ── Header Card ──────────────────────────────────────── *@
    <div class="job-header-card">
        <div class="job-header-top">
            <div class="job-header-logo">
                @if (!string.IsNullOrEmpty(Model.CompanyLogo))
                {
                    <img src="@Model.CompanyLogo" alt="@Model.CompanyName" />
                }
                else
                {
                    @(Model.CompanyName.Length > 0
                        ? Model.CompanyName.Substring(0, Math.Min(2, Model.CompanyName.Length)).ToUpper()
                        : "?")
                }
            </div>

            <div class="job-header-info">
                <div class="job-header-title">@Model.Title</div>
                <div class="job-header-company">@Model.CompanyName</div>
            </div>

            <div class="job-header-actions">
                <a href="#" class="btn-icon-action @(Model.IsSaved ? "saved" : "")" title="Save job">
                    <span class="iconify"
                          data-icon="@(Model.IsSaved ? "lucide:bookmark-check" : "lucide:bookmark")"></span>
                </a>
            </div>
        </div>

        <div class="job-header-meta">
            <span>
                <span class="iconify" data-icon="lucide:map-pin"></span>
                @Model.Location
            </span>
            <span>
                <span class="iconify" data-icon="lucide:clock"></span>
                Posted @Model.PostedDateDisplay
            </span>
            @if (!string.IsNullOrEmpty(Model.SalaryDisplay))
            {
                <span>
                    <span class="iconify" data-icon="lucide:dollar-sign"></span>
                    @Model.SalaryDisplay
                </span>
            }
            <span>
                <span class="iconify" data-icon="lucide:users"></span>
                @Model.ApplicantCount applicant@(Model.ApplicantCount != 1 ? "s" : "")
            </span>
        </div>

        <div class="job-header-tags">
            <span class="job-header-tag">@Model.JobType</span>
            @if (Model.WorkMode != "None")
            {
                <span class="job-header-tag">
                    @(Model.WorkMode == "OnSite" ? "On-Site" : Model.WorkMode)
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.CompanyIndustry))
            {
                <span class="job-header-tag">@Model.CompanyIndustry</span>
            }
        </div>

        @if (!Model.IsActive)
        {
            <div class="status-badge badge-rejected mb-3">This job is no longer accepting applications</div>
        }
        else if (Model.HasApplied)
        {
            <a href="#" class="btn-apply applied">
                <span class="iconify me-1" data-icon="lucide:check-circle"></span>
                Already Applied
            </a>
        }
        else if (User.Identity?.IsAuthenticated == true && User.IsInRole("Candidate"))
        {
            <a asp-controller="Jobs" asp-action="Apply" asp-route-jobId="@Model.Id"
               class="btn-apply">
                Apply Now
            </a>
        }
        else if (!User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Auth" asp-action="Login" class="btn-apply">
                Sign in to Apply
            </a>
        }
    </div>

    @* ── Job Description ──────────────────────────────────── *@
    <div class="job-section-card">
        <div class="job-section-title">Job Description</div>
        <div class="job-section-body">@Model.Description</div>
    </div>

    @* ── Requirements ─────────────────────────────────────── *@
    <div class="job-section-card">
        <div class="job-section-title">Requirements</div>
        <div class="job-section-body">@Model.Requirements</div>
    </div>

    @* ── Benefits (optional) ──────────────────────────────── *@
    @if (!string.IsNullOrWhiteSpace(Model.Benefits))
    {
        <div class="job-section-card">
            <div class="job-section-title">What We Offer</div>
            <div class="job-section-body">@Model.Benefits</div>
        </div>
    }

    @* ── Application Details ──────────────────────────────── *@
    <div class="job-section-card">
        <div class="job-section-title">Application Details</div>
        <div class="row g-3" style="font-size:.9rem;">
            <div class="col-6 col-sm-3">
                <div class="company-meta-item-label">Deadline</div>
                <div class="company-meta-item-value">@Model.ApplicationDeadline.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-6 col-sm-3">
                <div class="company-meta-item-label">Openings</div>
                <div class="company-meta-item-value">@Model.NumberOfOpenings</div>
            </div>
            <div class="col-6 col-sm-3">
                <div class="company-meta-item-label">Resume/CV</div>
                <div class="company-meta-item-value">@(Model.RequireCv ? "Required" : "Optional")</div>
            </div>
            <div class="col-6 col-sm-3">
                <div class="company-meta-item-label">Cover Letter</div>
                <div class="company-meta-item-value">@(Model.RequireCoverLetter ? "Required" : "Optional")</div>
            </div>
        </div>
    </div>

    @* ── About the Company ────────────────────────────────── *@
    <div class="job-section-card">
        <div class="job-section-title">About @Model.CompanyName</div>

        @if (!string.IsNullOrWhiteSpace(Model.CompanyDescription))
        {
            <div class="job-section-body mb-0">@Model.CompanyDescription</div>
        }

        @if (!string.IsNullOrEmpty(Model.CompanyIndustry) || !string.IsNullOrEmpty(Model.CompanySize))
        {
            <div class="company-meta-grid">
                @if (!string.IsNullOrEmpty(Model.CompanySize))
                {
                    <div>
                        <div class="company-meta-item-label">Company Size</div>
                        <div class="company-meta-item-value">
                            @(Model.CompanySize switch
                            {
                                "Mini" => "1–10 employees",
                                "Small" => "11–50 employees",
                                "Medium" => "51–250 employees",
                                "Large" => "251–1,000 employees",
                                "Enterprise" => "1,000+ employees",
                                _ => Model.CompanySize
                            })
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.CompanyIndustry))
                {
                    <div>
                        <div class="company-meta-item-label">Industry</div>
                        <div class="company-meta-item-value">@Model.CompanyIndustry</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.CreatedAt))
                {
                    <div>
                        <div class="company-meta-item-label">Founded</div>
                        <div class="company-meta-item-value">@Model.CreatedAt</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <div>
                        <div class="company-meta-item-label">Location</div>
                        <div class="company-meta-item-value">@Model.Location</div>
                    </div>
                }
            </div>
        }
    </div>

</div>
