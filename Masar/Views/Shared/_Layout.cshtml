<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] – MASAR</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/app.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-body">

    <!-- ── Top Navbar ──────────────────────────────────────── -->
    <nav class="app-navbar">
        <div class="app-navbar-inner">

            <!-- Brand -->
            <a asp-controller="Home" asp-action="Index" class="app-brand">
                MASAR<span>.</span>
            </a>
            
            <!-- Right side -->
            <div class="app-nav-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Authenticated: avatar dropdown -->
                    <div class="dropdown">
                        <button class="app-avatar-btn dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="app-avatar-initials">
                                @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end app-dropdown">
                            <li>
                                <a class="dropdown-item app-dropdown-item"
                                   asp-controller="Candidate" asp-action="Profile">
                                    <i class="bi bi-person me-2"></i> My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item app-dropdown-item"
                                   asp-controller="Candidate" asp-action="Dashboard">
                                    <i class="bi bi-grid me-2"></i> Dashboard
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item app-dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="app-nav-link">Sign In</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn-nav-cta">Get Started</a>
                }
            </div>
        </div>
    </nav>

    <!-- ── Page Body ───────────────────────────────────────── -->
    @if (ViewData["HasSidebar"] is true)
    {
        <!-- Sidebar layout -->
        <div class="app-shell">
            <aside class="app-sidebar" id="appSidebar">
                @await RenderSectionAsync("Sidebar", required: false)
            </aside>
            <main class="app-main">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
